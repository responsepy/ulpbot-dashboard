# ---------------------------------------------------------------
# ULPBot Dashboard — Environment Variables
# Copy this file to .env.local for local development.
# On Vercel: add both variables in Project Settings → Environment Variables.
# ---------------------------------------------------------------

# Backend API URL (public-facing, used client-side for rewrites baked at build time)
# On Vercel: set this BEFORE the first deploy so rewrites compile correctly.
NEXT_PUBLIC_API_BASE_URL=http://161.97.64.119:8000

# Backend API URL used server-side at request time (for the /api/upload proxy route).
# Must be reachable FROM Vercel's servers — use the same IP/domain as above.
# This is NOT exposed to the browser.
API_BASE_URL=http://161.97.64.119:8000
